# Supabase — get these from your Supabase project dashboard
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — used in Supabase Edge Functions only
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI — for Whisper speech-to-text (used in Edge Functions)
OPENAI_API_KEY=sk-your-key-here

# Alternative: Deepgram for speech-to-text
# DEEPGRAM_API_KEY=your-key-here

# Calling foundation (Plan 1)
PROVIDER_MODE=mock
SARVAM_API_KEY=
SARVAM_VOICE_ID=
SARVAM_BASE_URL=https://api.sarvam.ai
HUGGINGFACE_TOKEN=

# Hello-world outbound dial (Plan 1.5)
# Trial-account Plivo credentials. Verify your destination phone in the Plivo
# console before dialing — trial accounts can only call verified numbers.
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_SANDBOX_FROM=
# PHONE_ENCRYPTION_KEY is passed as an RPC parameter to encrypt_phone /
# get_elder_phone_e164 (see migration 021). Set it as an Edge Function secret
# (`supabase secrets set PHONE_ENCRYPTION_KEY=...`) and as a local env var for
# scripts that touch phone data (seed-test-family.ts, smoke-mock-mode.sh).
# Use the SAME value across env contexts for a given project — rotating
# requires re-encrypting every elder row.
PHONE_ENCRYPTION_KEY=

# Supabase (server-side / Edge Function context)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Operator scripts
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
TEST_ELDER_PHONE=
TEST_ELDER_NAME=
TEST_ELDER_LANG=kn
ELDER_ID=
FAMILY_SUGGESTED=
