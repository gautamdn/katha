# Supabase — get these from your Supabase project dashboard
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — used in Supabase Edge Functions only
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI — for Whisper speech-to-text (used in Edge Functions)
OPENAI_API_KEY=sk-your-key-here

# Alternative: Deepgram for speech-to-text
# DEEPGRAM_API_KEY=your-key-here

# Calling foundation (Plan 1)
PROVIDER_MODE=mock
SARVAM_API_KEY=
SARVAM_VOICE_ID=
SARVAM_BASE_URL=https://api.sarvam.ai
HUGGINGFACE_TOKEN=
# PHONE_ENCRYPTION_KEY is NOT read from env at runtime — set it on the database via:
#   ALTER DATABASE postgres SET app.phone_encryption_key = '<key>';
# Keep this entry as a reminder when provisioning a new Supabase project.
PHONE_ENCRYPTION_KEY=

# Supabase (server-side / Edge Function context)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Operator scripts
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
TEST_ELDER_PHONE=
TEST_ELDER_NAME=
TEST_ELDER_LANG=kn
ELDER_ID=
FAMILY_SUGGESTED=
